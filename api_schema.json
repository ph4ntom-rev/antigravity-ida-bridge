{
  "meta": {
    "name": "Antigravity IDA Bridge",
    "version": "4.0",
    "base_url": "http://127.0.0.1:13370",
    "description": "Full IDA Pro SDK API exposed via REST. All addresses are hex strings (e.g. '0x140001000'). All responses are JSON."
  },
  "system_prompt": "You are an expert reverse engineering AI agent with direct programmatic access to IDA Pro via the Antigravity Bridge HTTP API. You can read disassembly, decompile functions, inspect types, modify the database, run the debugger, and execute arbitrary IDAPython scripts. Always use structured API calls when a dedicated endpoint exists. Fall back to /api/exec only for operations not covered by dedicated endpoints. When analyzing binaries: 1) Start with /api/info to understand the target. 2) Use /api/functions-page to browse functions. 3) Decompile interesting functions and analyze their ctree/microcode. 4) Follow cross-references to map call chains. 5) Rename and comment as you discover functionality. 6) Use /api/batch for bulk mutations. Think step by step. Verify your hypotheses by examining xrefs, strings, and call graphs before making conclusions.",
  "capabilities": [
    "Decompile any function to C pseudocode",
    "Get AST (ctree) of decompiled functions for pattern matching",
    "Get microcode IR for deobfuscation analysis",
    "Read/write bytes, patch binary",
    "Rename functions, variables; set types and comments",
    "Create/modify/delete structs, enums, types",
    "Search by name, byte pattern, text, strings",
    "Navigate cross-references (code + data)",
    "Inspect vtables, call graphs, basic blocks (CFG)",
    "Full debugger control: breakpoints, stepping, registers, memory",
    "Execute arbitrary IDAPython scripts via /api/exec",
    "Batch mutations with rollback support",
    "Manage segments, type libraries, bookmarks"
  ],
  "endpoints": {
    "read": [
      {"method":"GET","path":"/api/ping","desc":"Health check","params":[],"returns":"status, version"},
      {"method":"GET","path":"/api/info","desc":"Binary metadata: filename, processor, bitness, entry point, address range","params":[],"returns":"filename, processor, bitness, entry_point, min_ea, max_ea, hexrays_available"},
      {"method":"GET","path":"/api/functions","desc":"List all functions (max 5000)","params":[],"returns":"functions[{ea,name,size}], total, truncated"},
      {"method":"GET","path":"/api/functions-page","desc":"Paginated function list","params":[{"name":"offset","type":"int","default":0},{"name":"limit","type":"int","default":500}],"returns":"functions[], offset, limit, returned, total"},
      {"method":"GET","path":"/api/function/<ea>/pseudocode","desc":"Decompile function to C pseudocode","params":[{"name":"ea","in":"path"}],"returns":"ea, name, pseudocode, local_vars[{name,type,is_arg}]"},
      {"method":"GET","path":"/api/function/<ea>/disasm","desc":"Disassembly listing","params":[{"name":"ea","in":"path"}],"returns":"ea, name, disasm[{ea,text}]"},
      {"method":"GET","path":"/api/function/<ea>/xrefs-to","desc":"Cross-references TO this address","params":[{"name":"ea","in":"path"}],"returns":"xrefs_to[{from_ea,from_func,type}], count"},
      {"method":"GET","path":"/api/function/<ea>/xrefs-from","desc":"Cross-references FROM this function","params":[{"name":"ea","in":"path"}],"returns":"xrefs_from[{to_ea,to_func,type}], count"},
      {"method":"GET","path":"/api/function/<ea>/details","desc":"Detailed function info: prototype, flags, frame","params":[{"name":"ea","in":"path"}],"returns":"ea, name, size, flags, prototype, comment, frame_size"},
      {"method":"GET","path":"/api/function/<ea>/call-graph","desc":"Recursive call graph","params":[{"name":"ea","in":"path"},{"name":"depth","type":"int","default":3}],"returns":"tree of {ea, name, calls[], call_count}"},
      {"method":"GET","path":"/api/function/<ea>/basic-blocks","desc":"Control flow graph (basic blocks)","params":[{"name":"ea","in":"path"}],"returns":"blocks[{start,end,size,successors,predecessors}]"},
      {"method":"GET","path":"/api/function/<ea>/stack-vars","desc":"Stack variables","params":[{"name":"ea","in":"path"}],"returns":"stack_vars[{name,offset,size}]"},
      {"method":"GET","path":"/api/function/<ea>/args","desc":"Function arguments from decompiler","params":[{"name":"ea","in":"path"}],"returns":"args[{name,type,index}]"},
      {"method":"GET","path":"/api/function/<ea>/comment","desc":"Read all comments at address","params":[{"name":"ea","in":"path"}],"returns":"comment, repeatable_comment, func_comment"},
      {"method":"GET","path":"/api/function/<ea>/ctree","desc":"Hex-Rays AST (ctree) as JSON. Each node has kind(insn/expr), op, ea, dtype. Expressions include value/string/obj_ea/var_name/call_target where applicable.","params":[{"name":"ea","in":"path"}],"returns":"ctree[{kind,op,ea,dtype,...}], count"},
      {"method":"GET","path":"/api/function/<ea>/lvar-map","desc":"Full local variable map with types, register/stack info","params":[{"name":"ea","in":"path"}],"returns":"lvars[{idx,name,type,is_arg,is_stk,is_reg,width}]"},
      {"method":"GET","path":"/api/function/<ea>/microcode","desc":"Microcode IR listing. Maturity: 0=PREOPT..7=LVARS. Higher = more optimized.","params":[{"name":"ea","in":"path"},{"name":"maturity","type":"int","default":7}],"returns":"microcode[{block,ea,text}], count"},
      {"method":"GET","path":"/api/function/<ea>/callers","desc":"Functions that call this function","params":[{"name":"ea","in":"path"}],"returns":"callers[{ea,name,call_site}]"},
      {"method":"GET","path":"/api/function/<ea>/callees","desc":"Functions called by this function","params":[{"name":"ea","in":"path"}],"returns":"callees[{ea,name,call_site}]"},
      {"method":"GET","path":"/api/function/<ea>/strings-used","desc":"String constants referenced by this function","params":[{"name":"ea","in":"path"}],"returns":"strings[{ea,ref_from,value}]"},
      {"method":"GET","path":"/api/strings","desc":"All strings in binary","params":[{"name":"filter","type":"regex","optional":true}],"returns":"strings[{ea,value,length}]"},
      {"method":"GET","path":"/api/imports","desc":"Imported functions grouped by module","params":[],"returns":"imports{module:[{ea,name,ordinal}]}"},
      {"method":"GET","path":"/api/exports","desc":"Exported functions","params":[],"returns":"exports[{ea,name,ordinal}]"},
      {"method":"GET","path":"/api/segments","desc":"Memory segments","params":[],"returns":"segments[{ea,end_ea,name,size,perm}]"},
      {"method":"GET","path":"/api/structs","desc":"All defined structures","params":[],"returns":"structs[{id,name,size}]"},
      {"method":"GET","path":"/api/struct/<name>","desc":"Structure members","params":[{"name":"name","in":"path"}],"returns":"members[{name,offset,size,type}]"},
      {"method":"GET","path":"/api/enums","desc":"All enums","params":[],"returns":"enums[{id,name,count}]"},
      {"method":"GET","path":"/api/enum/<name>","desc":"Enum members","params":[{"name":"name","in":"path"}],"returns":"members[{name,value}]"},
      {"method":"GET","path":"/api/names","desc":"Named items","params":[{"name":"filter","optional":true}],"returns":"names[{ea,name}]"},
      {"method":"GET","path":"/api/search-func/<name>","desc":"Find function by name (partial match)","params":[{"name":"name","in":"path"}],"returns":"results[{ea,name}]"},
      {"method":"GET","path":"/api/search-bytes/<pattern>","desc":"Search byte pattern. Use ?? for wildcards. Example: E8 ?? ?? ?? ?? 48 8B","params":[{"name":"pattern","in":"path"}],"returns":"results[{ea,func,func_ea}]"},
      {"method":"GET","path":"/api/search-text/<text>","desc":"Search text in disassembly","params":[{"name":"text","in":"path"}],"returns":"results[{ea,disasm,func}]"},
      {"method":"GET","path":"/api/bytes/<ea>/<size>","desc":"Read raw bytes","params":[{"name":"ea","in":"path"},{"name":"size","in":"path"}],"returns":"hex string"},
      {"method":"GET","path":"/api/vtable/<ea>","desc":"Read vtable entries","params":[{"name":"ea","in":"path"}],"returns":"entries[{index,ea,target,name}]"},
      {"method":"GET","path":"/api/global-vars","desc":"Global variables (non-function named data)","params":[],"returns":"global_vars[{ea,name,size}]"},
      {"method":"GET","path":"/api/bookmarks","desc":"IDA bookmarks","params":[],"returns":"bookmarks[{slot,ea,description}]"},
      {"method":"GET","path":"/api/patches","desc":"Patched bytes","params":[],"returns":"patches[{ea,original,patched}]"},
      {"method":"GET","path":"/api/gaps","desc":"Gaps between functions (undiscovered code)","params":[],"returns":"gaps[{start,end,size}]"},
      {"method":"GET","path":"/api/types","desc":"All local types","params":[],"returns":"types[{ordinal,name,type,size}]"},
      {"method":"GET","path":"/api/type/<name>","desc":"Type details with struct/union members","params":[{"name":"name","in":"path"}],"returns":"name, type, size, is_struct, members[]"},
      {"method":"GET","path":"/api/type-libraries","desc":"Loaded type libraries (TIL)","params":[],"returns":"libraries[{name,desc,ntypes}]"},
      {"method":"GET","path":"/api/insn/<ea>","desc":"Decoded instruction with operands","params":[{"name":"ea","in":"path"}],"returns":"ea, mnem, size, disasm, operands[{n,type,value,reg}]"},
      {"method":"GET","path":"/api/operands/<ea>","desc":"Operand details","params":[{"name":"ea","in":"path"}],"returns":"operands[{n,type,value,text}]"},
      {"method":"GET","path":"/api/data-xrefs/<ea>","desc":"Data cross-references only","params":[{"name":"ea","in":"path"}],"returns":"data_xrefs[{from,type,func}]"},
      {"method":"GET","path":"/api/code-xrefs/<ea>","desc":"Code cross-references only","params":[{"name":"ea","in":"path"}],"returns":"code_xrefs[{from,type,func}]"},
      {"method":"GET","path":"/api/cursor","desc":"Current cursor position in IDA","params":[],"returns":"ea, func, func_ea"},
      {"method":"GET","path":"/api/selection","desc":"Current selection range","params":[],"returns":"selected, start, end, size"},
      {"method":"GET","path":"/api/dbg/breakpoints","desc":"List breakpoints","params":[],"returns":"breakpoints[{ea,size,type,enabled}]"},
      {"method":"GET","path":"/api/dbg/regs","desc":"Read CPU registers (debugger must be active)","params":[],"returns":"registers{name:hex_value}"},
      {"method":"GET","path":"/api/dbg/threads","desc":"Thread list","params":[],"returns":"threads[{tid,name}]"},
      {"method":"GET","path":"/api/dbg/stack","desc":"Call stack trace","params":[],"returns":"stack[{caller,func,fp}]"},
      {"method":"GET","path":"/api/dbg/memory/<ea>/<size>","desc":"Read process memory (debugger)","params":[{"name":"ea","in":"path"},{"name":"size","in":"path"}],"returns":"ea, size, hex"},
      {"method":"GET","path":"/api/schema","desc":"This schema (self-documenting API)","params":[],"returns":"this JSON object"},
      {"method":"GET","path":"/api/wait-analysis","desc":"Block until auto-analysis completes","params":[],"returns":"success"}
    ],
    "write": [
      {"method":"POST","path":"/api/function/<ea>/rename","desc":"Rename function","body":{"name":"string"}},
      {"method":"POST","path":"/api/function/<ea>/comment","desc":"Set function comment","body":{"comment":"string"}},
      {"method":"POST","path":"/api/function/<ea>/lvar-rename","desc":"Rename local variable","body":{"old":"string","new":"string"}},
      {"method":"POST","path":"/api/function/<ea>/lvar-set-type","desc":"Change local variable type","body":{"var":"variable_name","type":"C_type_string"}},
      {"method":"POST","path":"/api/function/<ea>/lvar-comment","desc":"Comment on local variable","body":{"var":"variable_name","comment":"string"}},
      {"method":"POST","path":"/api/function/<ea>/set-type","desc":"Set function prototype","body":{"type":"int __fastcall(int a1, char *a2)"}},
      {"method":"POST","path":"/api/address/<ea>/comment","desc":"Set inline comment","body":{"comment":"string"}},
      {"method":"POST","path":"/api/struct/create","desc":"Create struct from C definition","body":{"definition":"struct Foo { int x; char *name; };"}},
      {"method":"POST","path":"/api/struct/add-member","desc":"Add struct member","body":{"struct":"name","member":"field_name","offset":0,"size":4,"type":"optional"}},
      {"method":"POST","path":"/api/enum/create","desc":"Create enum","body":{"name":"string"}},
      {"method":"POST","path":"/api/enum/add-member","desc":"Add enum member","body":{"enum":"name","member":"member_name","value":0}},
      {"method":"POST","path":"/api/type/create","desc":"Create type from C declaration","body":{"definition":"typedef struct {...} MyType;"}},
      {"method":"POST","path":"/api/type/delete","desc":"Delete local type","body":{"name":"type_name"}},
      {"method":"POST","path":"/api/type-library/load","desc":"Load type information library","body":{"name":"ntapi"}},
      {"method":"POST","path":"/api/segment/create","desc":"Create new segment","body":{"start":"0x...","end":"0x...","name":"seg","class":"DATA","bitness":2}},
      {"method":"POST","path":"/api/segment/delete","desc":"Delete segment","body":{"ea":"0x..."}},
      {"method":"POST","path":"/api/segment/set-attrs","desc":"Modify segment attributes","body":{"ea":"0x...","name":"opt","class":"opt","perm":"rwx"}},
      {"method":"POST","path":"/api/set-name","desc":"Set name at any address","body":{"ea":"0x...","name":"string"}},
      {"method":"POST","path":"/api/set-color","desc":"Set address background color","body":{"ea":"0x...","color":"0x00FF00"}},
      {"method":"POST","path":"/api/make-func","desc":"Create function at address","body":{"ea":"0x..."}},
      {"method":"POST","path":"/api/delete-func","desc":"Delete function","body":{"ea":"0x..."}},
      {"method":"POST","path":"/api/patch-bytes","desc":"Patch bytes in binary","body":{"ea":"0x...","bytes":"90 90 90"}},
      {"method":"POST","path":"/api/make-code","desc":"Convert to code","body":{"ea":"0x..."}},
      {"method":"POST","path":"/api/make-data","desc":"Convert to data","body":{"ea":"0x...","size":4}},
      {"method":"POST","path":"/api/undefine","desc":"Undefine bytes","body":{"ea":"0x...","size":1}},
      {"method":"POST","path":"/api/apply-struct","desc":"Apply struct at address","body":{"ea":"0x...","struct":"name"}},
      {"method":"POST","path":"/api/delete-struct","desc":"Delete structure","body":{"name":"string"}},
      {"method":"POST","path":"/api/delete-enum","desc":"Delete enum","body":{"name":"string"}},
      {"method":"POST","path":"/api/add-bookmark","desc":"Add bookmark","body":{"ea":"0x...","description":"string"}},
      {"method":"POST","path":"/api/delete-bookmark","desc":"Delete bookmark","body":{"slot":0}},
      {"method":"POST","path":"/api/import-header","desc":"Import C header file","body":{"path":"C:/path/to/header.h"}},
      {"method":"POST","path":"/api/reanalyze","desc":"Force reanalysis of range","body":{"start":"0x...","end":"0x..."}},
      {"method":"POST","path":"/api/save","desc":"Save IDA database","body":{}},
      {"method":"POST","path":"/api/undo","desc":"Undo last action","body":{}},
      {"method":"POST","path":"/api/redo","desc":"Redo action","body":{}},
      {"method":"POST","path":"/api/navigate","desc":"Move cursor to address","body":{"ea":"0x..."}},
      {"method":"POST","path":"/api/batch","desc":"Execute batch mutations atomically with rollback. Ops: rename-func, comment-func, comment, rename-var, create-struct, set-type","body":{"mutations":[{"op":"rename-func","ea":"0x...","name":"new_name"}]}},
      {"method":"POST","path":"/api/exec","desc":"Execute arbitrary IDAPython script. Full IDA SDK access. Use result dict to return data. Print statements captured in stdout.","body":{"script":"import ida_funcs\\nresult['count'] = ida_funcs.get_func_qty()"}},
      {"method":"POST","path":"/api/dbg/start","desc":"Start process (debugger)","body":{"path":"optional","args":"","sdir":"optional"}},
      {"method":"POST","path":"/api/dbg/attach","desc":"Attach to process","body":{"pid":1234}},
      {"method":"POST","path":"/api/dbg/detach","desc":"Detach from process","body":{}},
      {"method":"POST","path":"/api/dbg/breakpoint","desc":"Set breakpoint","body":{"ea":"0x...","hardware":false}},
      {"method":"POST","path":"/api/dbg/del-breakpoint","desc":"Delete breakpoint","body":{"ea":"0x..."}},
      {"method":"POST","path":"/api/dbg/step-into","desc":"Step into","body":{}},
      {"method":"POST","path":"/api/dbg/step-over","desc":"Step over","body":{}},
      {"method":"POST","path":"/api/dbg/continue","desc":"Continue execution","body":{}},
      {"method":"POST","path":"/api/dbg/pause","desc":"Pause/suspend process","body":{}},
      {"method":"POST","path":"/api/dbg/write-memory","desc":"Write process memory","body":{"ea":"0x...","bytes":"90 90"}}
    ]
  },
  "workflows": [
    {
      "name": "Analyze unknown binary",
      "steps": [
        "GET /api/info — understand target architecture",
        "GET /api/strings — scan for interesting strings",
        "GET /api/imports — check imported APIs for clues",
        "GET /api/exports — find entry points",
        "GET /api/functions-page?offset=0&limit=100 — browse functions",
        "GET /api/function/<ea>/pseudocode — decompile interesting functions",
        "GET /api/function/<ea>/strings-used — check what strings a function uses",
        "POST /api/batch — rename and comment in bulk"
      ]
    },
    {
      "name": "Trace specific functionality",
      "steps": [
        "GET /api/strings?filter=keyword — find related strings",
        "GET /api/function/<ea>/xrefs-to — find who references the string",
        "GET /api/function/<ea>/pseudocode — read the referencing function",
        "GET /api/function/<ea>/callers — trace upward",
        "GET /api/function/<ea>/callees — trace downward",
        "GET /api/function/<ea>/call-graph?depth=4 — visualize call tree"
      ]
    },
    {
      "name": "Deobfuscate function",
      "steps": [
        "GET /api/function/<ea>/pseudocode — read initial decompilation",
        "GET /api/function/<ea>/ctree — inspect AST for patterns",
        "GET /api/function/<ea>/microcode?maturity=0 — view unoptimized microcode",
        "GET /api/function/<ea>/microcode?maturity=7 — view optimized microcode",
        "Compare maturity levels to understand compiler/obfuscator transformations"
      ]
    },
    {
      "name": "Reconstruct C++ class",
      "steps": [
        "GET /api/search-bytes/<vtable_pattern> — find vtable",
        "GET /api/vtable/<ea> — read virtual methods",
        "GET /api/function/<ea>/pseudocode — analyze each virtual method",
        "POST /api/struct/create — create class structure",
        "POST /api/function/<ea>/set-type — apply this* parameter type",
        "POST /api/batch — rename all methods"
      ]
    },
    {
      "name": "Dynamic analysis with debugger",
      "steps": [
        "POST /api/dbg/start — launch process",
        "POST /api/dbg/breakpoint — set breakpoint at target",
        "POST /api/dbg/continue — run until breakpoint",
        "GET /api/dbg/regs — inspect register state",
        "GET /api/dbg/memory/<ea>/<size> — read memory at runtime",
        "POST /api/dbg/step-over — step through code",
        "GET /api/dbg/stack — view call stack"
      ]
    }
  ],
  "tips": [
    "Use /api/exec for anything not covered by dedicated endpoints — it gives full IDAPython access",
    "Use /api/batch for bulk operations — it's atomic and supports rollback",
    "Always check /api/info first to know if Hex-Rays (decompiler) is available",
    "Use /api/function/<ea>/ctree for pattern matching instead of parsing pseudocode text",
    "Microcode maturity 0 shows raw translation, 7 shows fully optimized — useful for deobfuscation",
    "Debugger endpoints only work when a debug session is active",
    "Use /api/functions-page with pagination for large binaries (>5000 functions)",
    "Strings-used endpoint is faster than searching xrefs manually for string references in a function"
  ]
}
